# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=ecom_user
DB_PASS=ecom_pass123
DB_URL=postgresql://ecom_user:ecom_pass123@localhost:5432/ecommerce

# Kaggle API — get from kaggle.com > Account > Create New API Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Power BI Streaming Dataset push URL
# Get from: app.powerbi.com > New > Streaming Dataset > API
POWERBI_PUSH_URL=https://api.powerbi.com/beta/YOUR_WORKSPACE_ID/datasets/YOUR_DATASET_ID/rows

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000